# URL of your PolicyGPT backend
POLICYGPT_BASE_URL=http://localhost:8000

# Groq API key to use as LLM judge for faithfulness/correctness
GROQ_API_KEY=your_groq_key_here

# Model name for judging (can be same as backend)
JUDGE_MODEL=llama-3.3-70b-versatile

# Directory to store evaluation results
RESULTS_DIR=results